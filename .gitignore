# Typora Themes Repository Git Ignore
# Created to avoid committing copyrighted font files and other infringing content

# ============================================
# FONT FILES - AVOID COPYRIGHT INFRINGEMENT
# ============================================

# TrueType Fonts
*.ttf
*.TTF

# OpenType Fonts
*.otf
*.OTF

# Web Open Font Format
*.woff
*.WOFF
*.woff2
*.WOFF2

# Embedded OpenType
*.eot
*.EOT

# SVG Fonts
*.svg
*.SVG

# Font Collections
*.ttc
*.TTC
*.otc
*.OTC

# ============================================
# OPERATING SYSTEM FILES
# ============================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes
._*

# Thumbnails
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# Windows
*.lnk
*.url

# Linux
*~

