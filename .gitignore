# MkDocs
site/

# ============================================
# TESTING
# ============================================

# Cypress
cypress/videos/
cypress/screenshots/

# Playwright
test-results/
playwright-report/

# ============================================
# CUSTOM RULES FOR THIS REPOSITORY
# ============================================

# Ignore all font files in any directory
**/*.ttf
**/*.otf
**/*.woff
**/*.woff2
**/*.eot
**/*.svg

# But keep CSS files that reference fonts (these are safe)
!*.css

# Keep the Readme file
!Readme.md

# Keep JSON theme files
!*.json

# ============================================
# END OF .gitignore
# ============================================